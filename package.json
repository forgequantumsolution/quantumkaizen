{
  "name": "quantum-kaizen",
  "version": "1.0.0",
  "private": true,
  "description": "Quantum Kaizen — Enterprise Quality, Document & Learning Management Platform",
  "workspaces": [
    "client",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:client\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=client && npm run build --workspace=backend",
    "db:migrate": "npm run db:migrate --workspace=backend",
    "db:generate": "npm run db:generate --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
