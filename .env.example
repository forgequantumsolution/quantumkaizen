# Quantum Kaizen — Docker Compose environment
# Copy to .env (or let ./deploy.sh create one for you).
# deploy.sh will auto-generate JWT secrets + DB/MinIO passwords if missing.

# ─── Exposed ports ───────────────────────────────────────────────────
APP_PORT=80

# ─── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_DB=quantum_kaizen
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-db-password

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-strong-redis-password

# ─── MinIO (S3-compatible object storage) ────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-strong-minio-password
S3_BUCKET=quantum-kaizen-docs
S3_REGION=us-east-1

# ─── JWT (min 32 chars each — generate with: openssl rand -base64 48) ─
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS_AAAAAAAA
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_STRONG_RANDOM_SECRET_BBBBBB
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── CORS — allowed origin of the web client ─────────────────────────
# For same-host deploy (client on :80 proxying /api to server), this is fine.
CORS_ORIGIN=http://localhost

# ─── SMTP (optional) ─────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Quantum Kaizen <noreply@quantumkaizen.io>

# ─── First-boot seed ─────────────────────────────────────────────────
# Set to 1 to seed demo tenant + users on container start (safe: uses upsert).
SEED_ON_START=1
